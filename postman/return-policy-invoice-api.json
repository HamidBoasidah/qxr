{
  "info": {
    "name": "Return Policy & Invoice API",
    "description": "مجموعة اختبار API لنظام سياسات الاسترجاع وفواتير الاسترجاع",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Sanctum token — يُملأ تلقائياً بعد تسجيل الدخول"
    },
    {
      "key": "policy_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "return_invoice_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "invoice_id",
      "value": "1",
      "type": "string"
    },
    {
      "key": "invoice_item_id",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (Company)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"company@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Login (Customer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "  pm.collectionVariables.set('token', res.token);",
                  "  console.log('Token saved:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@example.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": ["{{base_url}}"],
              "path": ["login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/logout",
              "host": ["{{base_url}}"],
              "path": ["logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Return Policies (Company)",
      "item": [
        {
          "name": "List Return Policies",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-policies",
              "host": ["{{base_url}}"],
              "path": ["return-policies"]
            }
          }
        },
        {
          "name": "Create Return Policy",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('policy_id', res.data.id);",
                  "  console.log('Policy ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"سياسة الاسترجاع القياسية\",\n  \"return_window_days\": 30,\n  \"max_return_ratio\": 1.00,\n  \"bonus_return_enabled\": false,\n  \"bonus_return_ratio\": null,\n  \"discount_deduction_enabled\": true,\n  \"min_days_before_expiry\": 0,\n  \"is_default\": true,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-policies",
              "host": ["{{base_url}}"],
              "path": ["return-policies"]
            }
          }
        },
        {
          "name": "Create Return Policy (with Bonus)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"سياسة مع بونص\",\n  \"return_window_days\": 14,\n  \"max_return_ratio\": 0.50,\n  \"bonus_return_enabled\": true,\n  \"bonus_return_ratio\": 0.50,\n  \"discount_deduction_enabled\": false,\n  \"min_days_before_expiry\": 7,\n  \"is_default\": false,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-policies",
              "host": ["{{base_url}}"],
              "path": ["return-policies"]
            }
          }
        },
        {
          "name": "Show Return Policy",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-policies/{{policy_id}}",
              "host": ["{{base_url}}"],
              "path": ["return-policies", "{{policy_id}}"]
            }
          }
        },
        {
          "name": "Update Return Policy",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"سياسة الاسترجاع المعدّلة\",\n  \"return_window_days\": 45,\n  \"max_return_ratio\": 0.75,\n  \"discount_deduction_enabled\": true,\n  \"min_days_before_expiry\": 3,\n  \"is_active\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-policies/{{policy_id}}",
              "host": ["{{base_url}}"],
              "path": ["return-policies", "{{policy_id}}"]
            }
          }
        },
        {
          "name": "Delete Return Policy",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-policies/{{policy_id}}",
              "host": ["{{base_url}}"],
              "path": ["return-policies", "{{policy_id}}"]
            }
          }
        },
        {
          "name": "[422] Update Policy Linked to Invoices",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"محاولة تعديل سياسة مرتبطة بفواتير\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-policies/{{policy_id}}",
              "host": ["{{base_url}}"],
              "path": ["return-policies", "{{policy_id}}"]
            },
            "description": "يجب أن يُرجع 422 إذا كانت السياسة مرتبطة بفواتير"
          }
        }
      ]
    },
    {
      "name": "Return Invoices (Customer - Create)",
      "item": [
        {
          "name": "Create Return Invoice",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.id) {",
                  "  pm.collectionVariables.set('return_invoice_id', res.data.id);",
                  "  console.log('Return Invoice ID saved:', res.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_invoice_id\": {{invoice_id}},\n  \"items\": [\n    {\n      \"invoice_item_id\": {{invoice_item_id}},\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-invoices",
              "host": ["{{base_url}}"],
              "path": ["return-invoices"]
            },
            "description": "يجب تسجيل الدخول كعميل (customer) صاحب الفاتورة الأصلية"
          }
        },
        {
          "name": "[409] Create Duplicate Return Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_invoice_id\": {{invoice_id}},\n  \"items\": [\n    {\n      \"invoice_item_id\": {{invoice_item_id}},\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-invoices",
              "host": ["{{base_url}}"],
              "path": ["return-invoices"]
            },
            "description": "يجب أن يُرجع 409 عند محاولة إنشاء فاتورة استرجاع مكررة"
          }
        },
        {
          "name": "[403] Create Return Invoice (Wrong Customer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_invoice_id\": {{invoice_id}},\n  \"items\": [\n    {\n      \"invoice_item_id\": {{invoice_item_id}},\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-invoices",
              "host": ["{{base_url}}"],
              "path": ["return-invoices"]
            },
            "description": "يجب أن يُرجع 403 إذا كان العميل ليس صاحب الفاتورة"
          }
        },
        {
          "name": "[422] Create Return Invoice (Unpaid Invoice)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"original_invoice_id\": {{invoice_id}},\n  \"items\": [\n    {\n      \"invoice_item_id\": {{invoice_item_id}},\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/return-invoices",
              "host": ["{{base_url}}"],
              "path": ["return-invoices"]
            },
            "description": "يجب أن يُرجع 422 إذا كانت الفاتورة غير مدفوعة"
          }
        }
      ]
    },
    {
      "name": "Return Invoices (Company - Manage)",
      "item": [
        {
          "name": "List Return Invoices",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-invoices?per_page=10",
              "host": ["{{base_url}}"],
              "path": ["return-invoices"],
              "query": [{ "key": "per_page", "value": "10" }]
            }
          }
        },
        {
          "name": "Show Return Invoice",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-invoices/{{return_invoice_id}}",
              "host": ["{{base_url}}"],
              "path": ["return-invoices", "{{return_invoice_id}}"]
            }
          }
        },
        {
          "name": "Approve Return Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-invoices/{{return_invoice_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["return-invoices", "{{return_invoice_id}}", "approve"]
            },
            "description": "يجب تسجيل الدخول كشركة (company) صاحبة الفاتورة"
          }
        },
        {
          "name": "Reject Return Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-invoices/{{return_invoice_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["return-invoices", "{{return_invoice_id}}", "reject"]
            },
            "description": "يجب تسجيل الدخول كشركة (company) صاحبة الفاتورة"
          }
        },
        {
          "name": "[422] Approve Already Approved Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/return-invoices/{{return_invoice_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["return-invoices", "{{return_invoice_id}}", "approve"]
            },
            "description": "يجب أن يُرجع 422 عند محاولة قبول فاتورة مقبولة مسبقاً"
          }
        }
      ]
    }
  ]
}
